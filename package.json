{
    "author": "chrisofnormandy",
    "description": "Markdown components for React",
    "keywords": [],
    "license": "MIT",
    "name": "@dead-harbour/react-markdown",
    "packageManager": "yarn@4.16.0",
    "type": "module",
    "version": "1.0.0",
    "files": [
        "dist"
    ],
    "exports": {
        "./style.css": "./dist/react-markdown.css",
        ".": {
            "types": "./dist/lib/markdown.d.ts",
            "import": "./dist/markdown.js",
            "require": null
        }
    },
    "dependencies": {
        "@dead-harbour/shipshape": "1.0.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "sass": "^1.98.0"
    },
    "devDependencies": {
        "@dead-harbour/react-editors": "1.0.0",
        "@dead-harbour/react-elements": "1.0.0",
        "@dead-harbour/scss-rigging": "1.0.1",
        "@types/node": "^25.9.1",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "eslint": "^10.4.1",
        "knip": "^6.15.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tsc-alias": "^1.8.17",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    },
    "peerDependencies": {
        "@dead-harbour/react-editors": ">=1",
        "@dead-harbour/react-elements": ">=1",
        "@dead-harbour/scss-rigging": ">=1",
        "react": ">=19",
        "react-dom": ">=19"
    },
    "scripts": {
        "build:types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "build": "yarn clean; yarn build:types && vite build",
        "bump:pre": "npm version --commit-hooks false --git-tag-version false prerelease",
        "bump": "npm version --commit-hooks false --git-tag-version false patch",
        "clean": "rm -r ./dist",
        "dev": "DEV=1 vite",
        "lint": "eslint --fix",
        "prerelease": "yarn lint && yarn knip && yarn build && yarn bump:pre && git add --a",
        "release": "yarn lint && yarn knip && yarn build && yarn bump && git add --a",
        "sanity": "yarn typecheck && yarn lint && yarn knip",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
