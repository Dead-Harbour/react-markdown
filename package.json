{
    "author": "chrisofnormandy",
    "description": "Markdown and React Router components for React",
    "keywords": [],
    "license": "MIT",
    "name": "@syren-dev-tech/confects-md",
    "packageManager": "yarn@4.13.0",
    "type": "module",
    "version": "0.2.0-2",
    "files": [
        "dist"
    ],
    "exports": {
        "./style.css": "./dist/confects-md.css",
        ".": {
            "types": "./dist/lib/markdown.d.ts",
            "import": "./dist/confects-md.js",
            "require": null
        }
    },
    "dependencies": {
        "@syren-dev-tech/concauses": "^0.1.3",
        "@syren-dev-tech/confects": "^0.2.1-2",
        "@syren-dev-tech/confects-editors": "^0.2.0-0",
        "@syren-dev-tech/confetti": "^0.2.1-0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "sass": "^1.98.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^9.39.4",
        "knip": "^6.2.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tsc-alias": "^1.8.16",
        "typescript": "^6.0.2",
        "vite": "^8.0.3"
    },
    "peerDependencies": {
        "@syren-dev-tech/confects": ">=0.2",
        "@syren-dev-tech/confects-editors": ">=0.2",
        "@syren-dev-tech/confetti": ">=0.2",
        "react": ">=19",
        "react-dom": ">=19"
    },
    "scripts": {
        "build:types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "build": "yarn clean; yarn build:types && vite build",
        "bump:pre": "npm version --commit-hooks false --git-tag-version false prerelease",
        "bump": "npm version --commit-hooks false --git-tag-version false patch",
        "clean": "rm -r ./dist",
        "dev": "DEV=1 vite",
        "lint": "eslint --fix",
        "prerelease": "yarn lint && yarn knip && yarn build && yarn bump:pre && git add --a",
        "release": "yarn lint && yarn knip && yarn build && yarn bump && git add --a",
        "sanity": "yarn typecheck && yarn lint && yarn knip",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}